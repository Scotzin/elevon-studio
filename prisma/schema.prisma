// Banco de dados da área da equipe (PostgreSQL — produção e dev).
// Defina DATABASE_URL no .env (local) e nas variáveis da Vercel (produção).
// Para regenerar o client: npx prisma generate
// Para criar/atualizar as tabelas: npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Membros da equipe que podem fazer login (contas fixas, criadas no seed).
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  role         String
  passwordHash String
  createdAt    DateTime @default(now())
}

// Cada visita a uma página do site (tráfego real) vira uma linha aqui.
model PageView {
  id        String   @id @default(cuid())
  path      String
  visitorId String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}

// Gastos/custos da empresa (mostrados na aba Gastos do painel).
model Expense {
  id         String   @id @default(cuid())
  name       String
  category   String   @default("Outros") // IA, Anúncios, Domínio, Impostos, Outros
  amount     Float    @default(0) // valor em R$
  recurrence String   @default("mensal") // mensal, anual, única
  createdAt  DateTime @default(now())
}
