# Copie este arquivo para ".env" e preencha os valores.
# Estas variáveis também devem ser configuradas na Vercel (Settings > Environment Variables).

# Conexão com o banco PostgreSQL.
# Neon/Vercel Postgres: use a connection string (com ?sslmode=require).
DATABASE_URL="postgresql://usuario:senha@host:5432/elevon?sslmode=require"

# Segredo para assinar a sessão de login (cookie JWT).
# Gere um valor aleatório longo, ex.: openssl rand -hex 32
AUTH_SECRET="troque-por-um-valor-aleatorio-longo-e-secreto"

# (Opcional) Senha inicial das contas da equipe ao rodar "node prisma/seed.mjs".
# Em produção, defina uma senha forte aqui antes de rodar o seed.
SEED_PASSWORD="defina-uma-senha-forte"
